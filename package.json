{
  "name": "projectcycle",
  "displayName": "ProjectCycle",
  "description": "Cycle through open VSCode windows with priority ordering",
  "version": "0.0.1",
  "publisher": "mahmutsalman",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0e0e1a",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectcycle-sidebar",
          "title": "ProjectCycle",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "projectcycle-sidebar": [
        {
          "id": "projectcycle.priorityView",
          "name": "Priority Cycle (Ctrl+,)"
        },
        {
          "id": "projectcycle.allView",
          "name": "All Projects (Ctrl+.)"
        }
      ]
    },
    "commands": [
      {
        "command": "projectcycle.cyclePriority",
        "title": "ProjectCycle: Cycle Priority Projects"
      },
      {
        "command": "projectcycle.cycleAll",
        "title": "ProjectCycle: Cycle All Projects"
      },
      {
        "command": "projectcycle.addCurrent",
        "title": "Add Current Project",
        "icon": "$(add)"
      },
      {
        "command": "projectcycle.refreshPriorityView",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "projectcycle.moveUp",
        "title": "Move Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "projectcycle.moveDown",
        "title": "Move Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "projectcycle.deleteProject",
        "title": "Remove from Priority Cycle",
        "icon": "$(trash)"
      },
      {
        "command": "projectcycle.addCurrentToAll",
        "title": "Add Current Project",
        "icon": "$(add)"
      },
      {
        "command": "projectcycle.refreshAllView",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "projectcycle.moveUpAll",
        "title": "Move Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "projectcycle.moveDownAll",
        "title": "Move Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "projectcycle.deleteProjectAll",
        "title": "Remove from All Projects",
        "icon": "$(trash)"
      },
      {
        "command": "projectcycle.assignColor",
        "title": "Assign Color",
        "icon": "$(symbol-color)"
      },
      {
        "command": "projectcycle.addFavorite",
        "title": "Add to Favorites",
        "icon": "$(star-empty)"
      },
      {
        "command": "projectcycle.removeFavorite",
        "title": "Remove from Favorites",
        "icon": "$(star-full)"
      },
      {
        "command": "projectcycle.activateProject",
        "title": "Open / Focus Project"
      },
      {
        "command": "projectcycle.closeProjectWindow",
        "title": "Close Window",
        "icon": "$(close)"
      },
      {
        "command": "projectcycle.cycleColorMode",
        "title": "Cycle Color Mode",
        "icon": "$(symbol-event)"
      },
      {
        "command": "projectcycle.toggleColorFreeze",
        "title": "Freeze / Unfreeze Color Animation",
        "icon": "$(pin)"
      },
      {
        "command": "projectcycle.tickColor",
        "title": "Step to Next Color State",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "projectcycle.openAllPriority",
        "title": "Open All Priority Projects",
        "icon": "$(run-all)"
      },
      {
        "command": "projectcycle.timerMenu",
        "title": "ProjectCycle: Timer Controls"
      },
      {
        "command": "projectcycle.goBack",
        "title": "ProjectCycle: Go to Previous Window"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "projectcycle.addCurrent",
          "when": "view == projectcycle.priorityView",
          "group": "navigation@1"
        },
        {
          "command": "projectcycle.refreshPriorityView",
          "when": "view == projectcycle.priorityView",
          "group": "navigation@2"
        },
        {
          "command": "projectcycle.cycleColorMode",
          "when": "view == projectcycle.priorityView",
          "group": "navigation@3"
        },
        {
          "command": "projectcycle.toggleColorFreeze",
          "when": "view == projectcycle.priorityView",
          "group": "navigation@4"
        },
        {
          "command": "projectcycle.tickColor",
          "when": "view == projectcycle.priorityView",
          "group": "navigation@5"
        },
        {
          "command": "projectcycle.openAllPriority",
          "when": "view == projectcycle.priorityView",
          "group": "navigation@6"
        },
        {
          "command": "projectcycle.addCurrentToAll",
          "when": "view == projectcycle.allView",
          "group": "navigation@1"
        },
        {
          "command": "projectcycle.refreshAllView",
          "when": "view == projectcycle.allView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "projectcycle.closeProjectWindow",
          "when": "view == projectcycle.priorityView && viewItem == priorityItemOpen",
          "group": "inline@0"
        },
        {
          "command": "projectcycle.closeProjectWindow",
          "when": "view == projectcycle.allView && (viewItem == allItemOpen || viewItem == allItemFavoriteOpen)",
          "group": "inline@0"
        },
        {
          "command": "projectcycle.moveUp",
          "when": "view == projectcycle.priorityView && (viewItem == priorityItem || viewItem == priorityItemOpen)",
          "group": "inline@1"
        },
        {
          "command": "projectcycle.moveDown",
          "when": "view == projectcycle.priorityView && (viewItem == priorityItem || viewItem == priorityItemOpen)",
          "group": "inline@2"
        },
        {
          "command": "projectcycle.deleteProject",
          "when": "view == projectcycle.priorityView && (viewItem == priorityItem || viewItem == priorityItemOpen)",
          "group": "inline@3"
        },
        {
          "command": "projectcycle.moveUpAll",
          "when": "view == projectcycle.allView && (viewItem == allItem || viewItem == allItemOpen || viewItem == allItemFavorite || viewItem == allItemFavoriteOpen)",
          "group": "inline@1"
        },
        {
          "command": "projectcycle.moveDownAll",
          "when": "view == projectcycle.allView && (viewItem == allItem || viewItem == allItemOpen || viewItem == allItemFavorite || viewItem == allItemFavoriteOpen)",
          "group": "inline@2"
        },
        {
          "command": "projectcycle.deleteProjectAll",
          "when": "view == projectcycle.allView && (viewItem == allItem || viewItem == allItemOpen || viewItem == allItemFavorite || viewItem == allItemFavoriteOpen)",
          "group": "inline@3"
        },
        {
          "command": "projectcycle.addFavorite",
          "when": "view == projectcycle.allView && (viewItem == allItem || viewItem == allItemOpen)",
          "group": "inline@4"
        },
        {
          "command": "projectcycle.removeFavorite",
          "when": "view == projectcycle.allView && (viewItem == allItemFavorite || viewItem == allItemFavoriteOpen)",
          "group": "inline@4"
        },
        {
          "command": "projectcycle.assignColor",
          "when": "view == projectcycle.priorityView && (viewItem == priorityItem || viewItem == priorityItemOpen)",
          "group": "1_actions@1"
        },
        {
          "command": "projectcycle.assignColor",
          "when": "view == projectcycle.allView && (viewItem == allItem || viewItem == allItemOpen || viewItem == allItemFavorite || viewItem == allItemFavoriteOpen)",
          "group": "1_actions@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "projectcycle.cyclePriority",
        "key": "ctrl+,",
        "mac": "ctrl+,"
      },
      {
        "command": "projectcycle.cycleAll",
        "key": "ctrl+.",
        "mac": "ctrl+."
      },
      {
        "command": "projectcycle.goBack",
        "key": "ctrl+;",
        "mac": "ctrl+;"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
